@using MPC.PlanSched.Shared.Common

<TelerikButton Icon="@SvgIcon.Calculator"
			   FillMode="@ThemeConstants.Button.FillMode.Flat"
			   Size="@ThemeConstants.Button.Size.Small"
			   OnClick="@OpenPopup"
			   Title="Bulk Override: Apply factor to all filtered records"
			   Enabled="@(!Disabled)">
</TelerikButton>

<TelerikWindow @bind-Visible="@IsVisible"
			   Modal="true"
			   Width="320px"
			   Height="auto"
			   Centered="true"
			   Class="bulk-override-window">
	<WindowTitle>
		<strong>@Title</strong>
	</WindowTitle>
	<WindowContent>
		<div class="p-3">
			<div class="mb-3">
				<label class="form-label">Enter Factor Value:</label>
				<TelerikNumericTextBox @bind-Value="@LocalValue"
									   Decimals="@Decimals"
									   Format="@Format"
									   Width="100%"
									   Placeholder="@Placeholder">
				</TelerikNumericTextBox>
			</div>
			<div class="d-flex gap-2">
				<TelerikButton OnClick="@HandleApply"
							   ThemeColor="@ThemeConstants.Button.ThemeColor.Primary"
							   Class="flex-fill"
							   Enabled="@LocalValue.HasValue">
					Apply
				</TelerikButton>
				<TelerikButton OnClick="@HandleClear"
							   ThemeColor="@ThemeConstants.Button.ThemeColor.Error"
							   Class="flex-fill">
					Clear
				</TelerikButton>
			</div>
		</div>
	</WindowContent>
	<WindowActions>
		<WindowAction Name="Close" OnClick="@HandleCancel" />
	</WindowActions>
</TelerikWindow>

@code {
	[Parameter]
	public string Title { get; set; } = "Bulk Override";

	[Parameter]
	public decimal? Value { get; set; }

	[Parameter]
	public EventCallback<decimal?> ValueChanged { get; set; }

	[Parameter]
	public EventCallback OnApplyClick { get; set; }

	[Parameter]
	public EventCallback OnClearClick { get; set; }

	[Parameter]
	public string Placeholder { get; set; } = "e.g., 1.2";

	[Parameter]
	public bool Disabled { get; set; }

	[Parameter]
	public int Decimals { get; set; } = 6;

	[Parameter]
	public string Format { get; set; } = "N6";

	private bool IsVisible { get; set; }
	private decimal? LocalValue { get; set; }

	protected override void OnParametersSet()
	{
		LocalValue = Value;
	}

	private void OpenPopup()
	{
		LocalValue = Value;
		IsVisible = true;
	}

	private async Task HandleApply()
	{
		if (LocalValue.HasValue)
		{
			await ValueChanged.InvokeAsync(LocalValue);
			await OnApplyClick.InvokeAsync();
			IsVisible = false;
		}
	}

	private async Task HandleClear()
	{
		LocalValue = null;
		await ValueChanged.InvokeAsync(null);
		await OnClearClick.InvokeAsync();
		IsVisible = false;
	}

	private void HandleCancel()
	{
		LocalValue = Value;
		IsVisible = false;
	}
}