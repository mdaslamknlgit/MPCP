@using Microsoft.FeatureManagement
@using Azure.Data.AppConfiguration
@using MPC.PlanSched.UI.ViewModel
@using MPC.PlanSched.Shared.Common;
@using MPC.PlanSched.Shared.Common.Extensions
@inject IFeatureManager featureManager
@inject ILogger<Spinner> logger

<TelerikLoaderContainer Visible="@IsVisible" LoaderType="@LoaderType.ConvergingSpinner" Text="@LoadingText" />

@code{
    [Parameter]
    public bool IsVisible { get; set; }
    private string LoadingText { get; set; }
    private string[] LoadingMessages { get; set; }
    private Random RandomNum = new Random();

    protected override async Task OnInitializedAsync()
    {
        LoadingText = await GenerateLoadingMessageAsync();
        await base.OnInitializedAsync();
    }

    public async Task<string> GenerateLoadingMessageAsync()
    {
        if (await featureManager.IsEnabledAsync(FeatureFlags.FunLoadingMessages)) 
        {
            try
            {
                string appConfigMessages = ConfigurationUI.getValue("LoadingMessages");

                LoadingMessages = appConfigMessages.Split("\r\n");

                int index = RandomNum.Next(LoadingMessages.Count());
                return LoadingMessages[index];
            }
            catch (Exception ex)
            {
                logger.LogMethodError(ex, "The following exception has occurred in GenerateLoadingMessages.");
                return "Please wait...";
            }
        }

        return "Please wait...";
    }
}