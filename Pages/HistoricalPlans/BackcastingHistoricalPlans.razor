@page "/{selectedRole}/regionalbackcasting/plans/historical"
@using MPC.PlanSched.Shared.Service.Schema
@using MPC.PlanSched.Model
@using Microsoft.Extensions.Logging
@inherits CommonBase

<Spinner IsVisible="@IsLoading()" />

<div class="row">
    <div class="col-12 m-space">
        <div class="font-600 font-26"><i class="fa-solid fa-folder-open" /> Regional Backcasting - List of Historical Plans</div>
    </div>
    <div class="col-12 m-space">
        <div class="font-20">Select a historical plan to view</div>
    </div>

    <div class="col-12">
        <TelerikGrid Data="@BusinessCases" Height="65vh"  Width="100%"
                     FilterMode="@GridFilterMode.FilterMenu"
                     FilterMenuType="@FilterMenuType.CheckBoxList" @ref="@HistoricalGridRPRef">
            <GridAggregates>
                <GridAggregate Field="Region" Aggregate="@GridAggregateType.Count" />
            </GridAggregates>
            <GridColumns>
                <GridColumn Field="Region" Title="Region">
                    <FooterTemplate>
                        Total Records: @context.Count
                    </FooterTemplate>
                </GridColumn>
                <GridColumn Field="RefineryName" Title="Refineries" />
                <GridColumn Field="Name" Title="Plan Name" />
                <GridColumn Field="Description" Title="Description" />
                <GridColumn Field="CreatedBy" Title="Plan Created By" />
                <GridColumn Field="CreatedOn" Title="@CreatedOn" />
                <GridColumn Field="UpdatedBy" Title="Last Updated By" />
                <GridColumn Field="UpdatedOn" Title="@UpdatedOn" />
                <GridColumn Title="">
                    <Template>
                        @{
                            var item = (BusinessCase)context;
                            <a id="viewSavedPlanButton" class="hand-pointer font-500 custom-link" @onclick="(() => ViewPlan(item))">View Saved Plan</a>
                        }
                    </Template>
                </GridColumn>
                <GridColumn Field="">
                    <Template>
                        @{
                            var item = (BusinessCase)context;
                            <div style="text-align: center;">
                                <i id="excelDownloadButton" class="fa-solid fa-download hand-pointer custom-link" @onclick="(() => {_selectedBusinessCase = item; _excelDialogRef.Open(); })"></i>
							</div>
                        }
                    </Template>
                </GridColumn>
            </GridColumns>
            <NoDataTemplate>
                <strong>No Data Available.</strong>
            </NoDataTemplate>
        </TelerikGrid>
    </div>
</div>
<ExcelDownloadDialog @ref="_excelDialogRef" SelectedPriceTypeChanged="@OnPriceTypeChanged"
	OnConfirm="() => ExcelDownloadAsync(_selectedBusinessCase)">
</ExcelDownloadDialog>




