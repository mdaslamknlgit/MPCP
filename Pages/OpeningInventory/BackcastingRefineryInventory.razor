@page "/backcastinginventory/{selectedRole}/{businessCaseId:int}/{isHistoricalPlan:bool}"
@using Microsoft.Extensions.Logging;
@using MPC.PlanSched.Service;
@using PlanSched.Shared.Common;
@using System.Globalization;

@inherits BackcastingInventoryInventoryBaseComponent

<Spinner IsVisible="@IsLoading()" />

<div class="row align-items-center">
	<div class="col">
		<div class="row">
			<div class="col-auto">
				<a class="fa fa-long-arrow-left text-decoration-none d-link" @onclick="() => NavigateToRegionBackcasting(SelectedRole)"></a>
			</div>
			<div class="col font-600">@UIConstants.EditPlan @RegionTitle <br />(@PlanDescription) </div>
		</div>
	</div>
	<div class="col">
		<div class="col font-600">@DataLoadingStatusMessage</div>
	</div>
	<div class="col-auto d-flex flex-column align-items-center">
		<a class="hand-pointer font-500 custom-link"
		@onclick="@(ReadOnlyFlag ? null : (() => _refreshModal.OpenAsync(RegionModel)))"
		style="@(ReadOnlyFlag ? "pointer-events: none; opacity: 0.5;" : "")">
			Refresh Data
		</a>
		<CascadingValue Value="SelectedRole">
			<a class="hand-pointer font-500 custom-link mt-2"
			@onclick="@(() => {_notificationModal.OpenAsync(RegionModel, SelectedRole,PlanNSchedConstant.Inventory); })">
				Alerts and Notification
			</a>
		</CascadingValue>
	</div>
	<div class="col-auto">
		<span class="font-14 font-700" id="region-updated-on">@PlanUpdatedOn</span>
		<div>
			<TelerikButton Id="inventory-excel-download-btn" OnClick="@(() => { _excelDialogRef.Open();})" Size="small"><i class="fa-solid fa-download"></i> Download</TelerikButton>
		</div>
	</div>
</div>
<div class="row m-title-text m-space">
    <div class="col-auto m-p">
		<div class="font-700">@UIConstants.PeriodStartDate</div>
		<div class="d-inline-block" id="period-start-date">@PeriodStartDate</div>
		<a @onclick="() => NavigateToRegionRP(SelectedRole)" class="d-none">
			<img src="../Images/Icon3.svg" width="30" height="20" class="m-r-10" />
		</a>
	</div>
    <div class="col-auto m-p">
        <div class="font-700">@UIConstants.LastPeriodEndDate</div>
        <div class="d-inline-block" id="period-end-date">@PeriodEndDate</div>
        <a @onclick="() => NavigateToRegionRP(SelectedRole)" class="d-none">
            <img src="../Images/Icon3.svg" width="30" height="20" class="m-r-10" />
        </a>
    </div>
	<div class="col"></div>
	<div class="col-3">
		<div class="font-700">Refinery/Regional</div>
        <TelerikDropDownList Data="@DataSources" @bind-Value="SelectedDataSource" DefaultText="All" OnChange="@RefineryAndCommodityOnChanged"></TelerikDropDownList>
	</div>
	<div class="col-3" style="display:none">
		<div class="font-700">Commodity Type</div>
		<TelerikDropDownList Data="@CommodityTypes" TextField="Name" ValueField="Id" @bind-Value="SelectedCommodityValue" DefaultText="All" OnChange="@RefineryAndCommodityOnChanged"> </TelerikDropDownList>
	</div>
</div>
<div class="row m-0">
	<div class="col p-0">
		<CascadingValue Value="ReadOnlyFlag">
            <TelerikGrid id="backcasting-inventory-grid" TItem="OpeningInventory" OnRead=@OnReadHandlerAsync
			@ref="@GridInventoryReference" 
			Height="60vh" Width="240vh"
			Sortable="true" Resizable="true"
			Groupable="true" FilterMode="@GridFilterMode.FilterMenu"
			FilterMenuType="@FilterMenuType.CheckBoxList"
			ShowColumnMenu="true" Reorderable="true" Pageable="false"
						 LoadGroupsOnDemand=@LoadGroupsOnInventory>

				<GridToolBarTemplate>
					<TelerikButton Size="sm"
								   ButtonType="@ButtonType.Submit"
								   @onclick="ToggleBackcastingInventoryGridGroupByCollapseAsync"
								   Icon="@( LoadGroupsOnInventory ? SvgIcon.Plus : SvgIcon.Minus )"
								   Title="@( LoadGroupsOnInventory ? "Expand" : "Collapse" )">
						Expand/Collapse all groups
					</TelerikButton>
				</GridToolBarTemplate>
				<GridAggregates>
					<GridAggregate Field=@nameof(OpeningInventory.OverrideOpeningInventoryMinCalculated) Aggregate="@GridAggregateType.Sum" />
					<GridAggregate Field=@nameof(OpeningInventory.SystemOpeningInventoryMin) Aggregate="@GridAggregateType.Sum" />
					<GridAggregate Field=@nameof(OpeningInventory.OverrideOpeningInventoryMaxCalculated) Aggregate="@GridAggregateType.Sum" />
					<GridAggregate Field=@nameof(OpeningInventory.SystemOpeningInventoryMax) Aggregate="@GridAggregateType.Sum" />
					<GridAggregate Field=@nameof(OpeningInventory.OverrideOpeningInventoryCalculated) Aggregate="@GridAggregateType.Sum" />
					<GridAggregate Field=@nameof(OpeningInventory.SystemOpeningInventory) Aggregate="@GridAggregateType.Sum" />
					<GridAggregate Field=@nameof(OpeningInventory.OCostOverride) Aggregate="@GridAggregateType.Sum" />
					<GridAggregate Field=@nameof(OpeningInventory.OCostsystem) Aggregate="@GridAggregateType.Sum" />
					<GridAggregate Field=@nameof(OpeningInventory.CommodityName) Aggregate="@GridAggregateType.Count" />
					<GridAggregate Field=@nameof(OpeningInventory.Location) Aggregate="@GridAggregateType.Count" />
				</GridAggregates>
				<GridSettings>
					<GridColumnMenuSettings Lockable="false">
						<GridColumnMenuChooser>
							<Template>
								@{
									var columns = context.Columns;
									foreach (var column in columns)
									{
										<GridColumnMenuChooserItem Title="@column.DisplayTitle" ColumnId="@column.Id" />
									}
								}
							</Template>
						</GridColumnMenuChooser>
					</GridColumnMenuSettings>
				</GridSettings>
				<GridColumns>
					<GridColumn Width="140px" Id="inventory-location-name" Field="Location" Title="Location" Locked="true">
                        <FilterMenuTemplate Context="context">
                            <Filter Data="@LocationOptions"
                                    Field="@(nameof(OpeningInventory.Location))" FilterDescriptor="@context.FilterDescriptor">
                            </Filter>
                        </FilterMenuTemplate>
						<GroupFooterTemplate>
							Sub Total
						</GroupFooterTemplate>
						<FooterTemplate>
							Total Records: @context.Count
						</FooterTemplate>
					</GridColumn>
                    <GridColumn Width="140px" Id="inventory-location-description" Field="LocationDescription" Title="Location Description" Locked="true" Visible=false> </GridColumn>

					<GridColumn Width="140px" Id="inventory-product-name" Field="CommodityName" Title="Commodity Name & PIMS Code" Locked="true">
                        <FilterMenuTemplate Context="context">
                            <Filter Data="@ProductOptions"
                                    Field="@(nameof(OpeningInventory.CommodityName))"
                                    FilterDescriptor="@context.FilterDescriptor">
                            </Filter>
                        </FilterMenuTemplate>
						<Template>
							@{
								<div>@((context as OpeningInventory).CommodityName)</div>
								<div>@((context as OpeningInventory).PIMSCode)</div>
							}
						</Template>
					</GridColumn>
					<GridColumn Width="140px" Id="inventory-product-description" Field="CommodityDescription" Title="Product Description" Locked="true"> </GridColumn>

					<GridColumn id="inventory-calculated" Width="120px" Field="OverrideOpeningInventoryCalculated" Title="Opening Inventory" Locked="true">
						<Template>
							@{
								var openingInventoryData = (OpeningInventory)context;
								<div class="@(CommonHelper.IsValueDifferent(openingInventoryData.SystemOpeningInventory, openingInventoryData.OverrideOpeningInventoryCalculated, Constant.DisplayQtyDecimalPlaces)
								? "d-input-different" : "d-none")">
                                    Overridden:  @openingInventoryData.DisplayInventoryQuantity(openingInventoryData.OverrideOpeningInventoryCalculated)
								</div>
								<div class="@((@CommonHelper.IsValueDifferent(openingInventoryData.SystemOpeningInventory, openingInventoryData.PreviousSystemOpeningInventory, Constant.DisplayQtyDecimalPlaces))? "d-input-different" : "d-none") ">
								Previous System: @(openingInventoryData.PreviousSystemOpeningInventory?.ToString("0.000") ?? string.Empty)
								</div>

								<div>System: @(openingInventoryData.SystemOpeningInventory?.ToString("0.000") ?? string.Empty)</div>
							}
						</Template>
						<GroupFooterTemplate>
							@context.Sum
						</GroupFooterTemplate>
						<FooterTemplate>
							<GridFooterSum AggregateResults="@context?.AggregateResults"
										   OverrideProperty=@nameof(OpeningInventory.OverrideOpeningInventoryCalculated)
										   InitialProperty=@nameof(OpeningInventory.SystemOpeningInventory)
										   PrecisionFormat="@UIConstants.InventoryQuantityDigitPrecisionFormat" />
						</FooterTemplate>
					</GridColumn>
					<GridColumn id="inventory-min-calculated" Width="110px" Field="OverrideOpeningInventoryMinCalculated" Title="Min" Locked="true">
						<Template>
							@{
								var openingInventoryData = (OpeningInventory)context;
								openingInventoryData.ValidateBackcastingInventoryValues();
								<div class="@(openingInventoryData.SetCssClassIfSystemMinInventoryNotEqualToOverrideMinInventory())">
                                    Overridden: @openingInventoryData.DisplayInventoryQuantity(openingInventoryData.OverrideOpeningInventoryMinCalculated)
								</div>
								<div class="@((@CommonHelper.IsValueDifferent(openingInventoryData.SystemOpeningInventoryMin, openingInventoryData.PreviousSystemOpeningInventoryMin, Constant.DisplayQtyDecimalPlaces))? "d-input-different" : "d-none") ">
									Previous System: @(openingInventoryData.PreviousSystemOpeningInventoryMin?.ToString("0.000") ?? string.Empty)
								</div>
								<div>System: @(openingInventoryData.SystemOpeningInventoryMin?.ToString("0.000") ?? string.Empty)</div>
								<span style="color:red">@openingInventoryData.MinCalculatedValidationMessage</span>
							}
						</Template>
						<GroupFooterTemplate>
							@context.Sum
						</GroupFooterTemplate>
						<FooterTemplate>
							<GridFooterSum AggregateResults="@context?.AggregateResults"
										   OverrideProperty=@nameof(OpeningInventory.OverrideOpeningInventoryMinCalculated)
										   InitialProperty=@nameof(OpeningInventory.SystemOpeningInventoryMin)
										   PrecisionFormat="@UIConstants.InventoryQuantityDigitPrecisionFormat" />
						</FooterTemplate>
					</GridColumn>
					<GridColumn id="inventory-max-calculated" Width="110px" Field="OverrideOpeningInventoryMaxCalculated" Title="Max" Locked="true">
						<Template>
							@{
								var openingInventoryData = (OpeningInventory)context;
								openingInventoryData.ValidateBackcastingInventoryValues();
								<div class="@(openingInventoryData.SetCssClassIfSystemMaxInventoryNotEqualToOverrideMaxInventory())">
                                    Overridden: @openingInventoryData.DisplayInventoryQuantity(openingInventoryData.OverrideOpeningInventoryMaxCalculated)
								</div>
								<div class="@((@CommonHelper.IsValueDifferent(openingInventoryData.SystemOpeningInventoryMax, openingInventoryData.PreviousSystemOpeningInventoryMax, Constant.DisplayQtyDecimalPlaces))? "d-input-different" : "d-none") ">
									Previous System: @(openingInventoryData.PreviousSystemOpeningInventoryMax?.ToString("0.000") ?? string.Empty)
								</div>
								<div>System: @(openingInventoryData.SystemOpeningInventoryMax?.ToString("0.000") ?? string.Empty)</div>
								<span style="color:red">@openingInventoryData.MaxCalculatedValidationMessage</span>
							}
						</Template>
						<GroupFooterTemplate>
							@context.Sum
						</GroupFooterTemplate>
						<FooterTemplate>
							<GridFooterSum AggregateResults="@context?.AggregateResults"
										   OverrideProperty=@nameof(OpeningInventory.OverrideOpeningInventoryMaxCalculated)
										   InitialProperty=@nameof(OpeningInventory.SystemOpeningInventoryMax)
										   PrecisionFormat="@UIConstants.InventoryQuantityDigitPrecisionFormat" />
						</FooterTemplate>
					</GridColumn>
					<GridColumn id="target-inventory" Width="120px" Field="Target" Title="Target Inventory" Locked="true"></GridColumn>
					

					<GridColumn Width="140px" Id="rp-inventory-override-absolute" Field="OverrideOpeningInventoryAbsolute" Title="Opening Inventory Override">
						<Template>
							@{
								var openingInventoryData = (OpeningInventory)context;
								openingInventoryData.ValidateBackcastingInventoryValues();
							}

                            <CascadingValue Value="ReadOnlyFlag">
								<InventoryInput Context="context"
												Precision="@InventoryQuantityDecimalPlaces"
												ValueFunc="InventoryData => GetValue(InventoryData.SystemOpeningInventory, InventoryData.OverrideOpeningInventoryCalculated, InventoryData.OverrideOpeningInventory, Constant.DisplayQtyDecimalPlaces)"
												OnChange="((ChangeEventArgs e) => OnInventoryOverride(e, context,UIConstants.AbsoluteEntityValue))" />
							</CascadingValue>
						</Template>
					</GridColumn>

						

					<GridColumn Width="140px" Id="min-inventory-override-absolute" Field="OverrideOpeningInventoryMinAbsolute" Title="Min Override">
						<Template>
							@{
								var openingInventoryData = (OpeningInventory)context;
								openingInventoryData.ValidateBackcastingInventoryValues();
							}

                            <CascadingValue Value="ReadOnlyFlag">
								<InventoryInput Context="context"
												Precision="@InventoryQuantityDecimalPlaces"
												ValueFunc="InventoryData => GetValue(InventoryData.SystemOpeningInventoryMin, InventoryData.OverrideOpeningInventoryMinCalculated, InventoryData.OverrideOpeningInventoryMin, Constant.DisplayQtyDecimalPlaces)"
												OnChange="((ChangeEventArgs e) => OnMinInventoryOverride(e, context, UIConstants.AbsoluteEntityValue))" />
							</CascadingValue>
						</Template>
						</GridColumn>

						
					<GridColumn Width="140px" Id="max-inventory-override-absolute" Field="OverrideOpeningInventoryMaxAbsolute" Title="Max Override">
						<Template>
							@{
								var openingInventoryData = (OpeningInventory)context;
								openingInventoryData.ValidateBackcastingInventoryValues();
							}

                            <CascadingValue Value="ReadOnlyFlag">
								<InventoryInput Context="context"
												Precision="@InventoryQuantityDecimalPlaces"
												ValueFunc="InventoryData => GetValue(InventoryData.SystemOpeningInventoryMax, InventoryData.OverrideOpeningInventoryMaxCalculated, InventoryData.OverrideOpeningInventoryMax, Constant.DisplayQtyDecimalPlaces)"
												OnChange="((ChangeEventArgs e) => OnMaxInventoryOverride(e, context, UIConstants.AbsoluteEntityValue))" />
							</CascadingValue>
						</Template>	
						</GridColumn>


                        <GridColumn id="inventory-uom" Width="110px" Field="InventoryUOM" Title="UOM"></GridColumn>
                        <GridColumn id="inventory-ocost" Width="110px" Field="OCostOverride" Title="OCost">
                            <Template>
                                @{
                                    var item = context as OpeningInventory;
                                    <div class="text-center">
                                        @item.DisplayInventoryPrice(item.OCostOverride)
                                   </div>
                                }
                            </Template>
                        </GridColumn>
						<GridColumn id="inventory-hcost" Width="110px" Field="HCostOverride" Title="HCost">
                            <Template>
                                @{
                                    var item = context as OpeningInventory;
                                    <div class="text-center">
                                        @item.DisplayInventoryPrice(item.HCostOverride)
                                   </div>
                                }
                            </Template>
                        </GridColumn>
						<GridColumn id="inventory-pcost" Width="110px" Field="PCostOverride" Title="PCost">
							<Template>
								@{
									var item = context as OpeningInventory;
									<div class="text-center">
										@item.DisplayInventoryPrice(item.PCostOverride)
									</div>
								}
							</Template>
						</GridColumn>
					<GridColumn id="inventory-cprice" Width="110px" Field="CPriceOverride" Title="CPrice">
						<Template>
							@{
								var item = context as OpeningInventory;
								<div class="text-center">
									@item.DisplayInventoryPrice(item.CPriceOverride)
								</div>
							}
						</Template>
					</GridColumn>
					<GridColumn id="inventory-modified-flag" Width="120px" Field="IsOverridden" Title="Data Override">
                            <Template>
                                @{
                                    var inventoryData = (OpeningInventory)context;
                                    inventoryData.SetOverrideFlag();
                                    <div class="text-center">@inventoryData.IsOverridden</div>
                                }
                            </Template>
                        </GridColumn>
					<GridColumn Width="140px" id="rp-demand-cost-updatedby" Field="UpdatedBy" Title="Updated By">
						<Template>
							@{
								var inventoryData = (OpeningInventory)context;
								<div class="text-center">@inventoryData.UpdatedBy</div>
							}
						</Template>
					</GridColumn>

					<GridColumn Width="140px" id="rp-demand-cost-updatedOn" Field="UpdatedOn" Title="Updated On">
						<Template>
							@{
								var inventoryData = (OpeningInventory)context;
								var updatedOn = _localTimeZoneName == PlanNSchedConstant.DefaultTimeZone
								? inventoryData.UpdatedOn.Value.ToLocalTime()
								: UtilityUI.ConvertUTCToLocal(inventoryData.UpdatedOn.Value, _localTimeZoneName);
							}
							<div class="text-center">@updatedOn</div>
						</Template>
					</GridColumn>

					<GridColumn Width="140px" Id="rp-inventory-source" Field="DataSource" Title="DataSource">
                        <Template>
                            @{
                                var inventoryData = (OpeningInventory)context;
                                <div class="text-center">@inventoryData.DataSource</div>
                            }
                        </Template>
                    </GridColumn>
					<GridColumn Width="140px" id="rp-inventory-comments" Field="Comments" Title="Comments">
						<Template>
							@{
								var inventoryData = (OpeningInventory)context;
							}
                            <input type="text" class="form-control" @bind="inventoryData.Comments" @oninput="(e) => ValidateCommentsLength(e, context)" disabled="@ReadOnlyFlag" />
						</Template>
					</GridColumn>
				</GridColumns>
				<NoDataTemplate>
					<strong>@UIConstants.NoDataAvailable</strong>
				</NoDataTemplate>
			 </TelerikGrid>
		</CascadingValue>
			</div>
	<div class="row text-end m-space m-top">
		<div class="col">
			@{
				var openingInventoryItems = (OpeningInventories);
				if (!string.IsNullOrEmpty(RegionName) && !ReadOnlyFlag)
				{
					<AuthorizeView Policy="@(EditPimsPermissionName(RegionName))" Context="auth">
						<TelerikButton Id="btn-save-inventory" ThemeColor="primary" ButtonType="@ButtonType.Submit" @onclick="(() => SaveOpeningInventoryAsync(openingInventoryItems))">Save</TelerikButton>
						<TelerikButton Id="btn-cancel-inventory-backCasting" ButtonType="@ButtonType.Button" @onclick="(() => CancelInventoryBackCastingAsync())">Cancel</TelerikButton>
					</AuthorizeView>
				}
			}
		</div>
		<TelerikWindow Modal="true" @bind-Visible="@StatusPopup">
			<WindowContent>
				<div class="row p-3 fs-6">@StatusMessageContent</div>
				<div class="text-center"><TelerikButton OnClick="Close">Ok</TelerikButton></div>
			</WindowContent>
		</TelerikWindow>
		<MPC.PlanSched.UI.Shared.RefreshDialog @ref="_refreshModal" />
		<ExcelDownloadDialog @ref="_excelDialogRef" SelectedPriceTypeChanged="@OnPriceTypeChanged"
							 OnConfirm="() => ExcelDownloadAsync()">
		</ExcelDownloadDialog>
		<MPC.PlanSched.UI.Shared.NotificationDialog @ref="_notificationModal" />
			</div>
</div>