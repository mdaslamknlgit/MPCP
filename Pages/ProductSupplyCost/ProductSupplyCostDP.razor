@page "/productsupplycostdp/{selectedRole}/{businessCaseId:int}/{isHistoricalPlan:bool}"
@using MPC.PlanSched.UI.ViewModel
@using Microsoft.Extensions.Logging;
@using MPC.PlanSched.Service;
@using MPC.PlanSched.Shared.Service.Schema;
@using PlanSched.Shared.Common;
@using System.Globalization;
@using MPC.PlanSched.UI.Pages.ProductSupplyCost.Components;
@using Microsoft.FeatureManagement

@inject IFeatureManager _featureManager
@inject ILogger<ProductSupplyCostDP> logger;

@inherits ProductSupplyCostBaseComponent

<Spinner IsVisible="@IsLoading()" />

<div class="row align-items-center">
    <div class="col">
        <div class="row">
            <div class="col-auto">
                <a class="fa fa-long-arrow-left text-decoration-none d-link" @onclick="() => NavigateToRegionDP(SelectedRole)"></a>
            </div>
            <div class="col font-600">@UIConstants.EditPlan @RegionTitle <br />(@PlanDescription) </div>
        </div>
    </div>
    <div class="col">
        <div class="col font-600">@DataLoadingStatusMessage</div>
    </div>
    <div class="col-auto">
        <span class="font-14 font-700" id="region-updated-on">@PlanUpdatedOn</span>
        <div>
            <TelerikButton Id="supply-dp-excel-download-btn" OnClick="@ExcelDownloadAsync" Size="small"><i class="fa-solid fa-download"></i> Download</TelerikButton>
        </div>
    </div>
</div>
<div class="row align-items-center">
    <div class="col">
        <span class="font-14 font-700">@UIConstants.PriceEffectiveDate @PriceEffectiveDate</span>
    </div>
</div>
<div class="row align-items-center m-title-text m-space">
    <div class="col-auto">
        <div class="font-700">@UIConstants.PlanningPeriod</div>
    </div>
    <div class="col-3">
        <TelerikDropDownList id="ddl-period" Data="@Periods" TextField="PeriodDisplayName" ValueField="PeriodID"
                             Value="@SelectedPeriodId" ValueChanged="@( (int v) => GetProductSupplyCostsOnPeriodSelectionChangedAsync(v) )">
            <DropDownListSettings>
                <DropDownListPopupSettings Height="auto" />
            </DropDownListSettings>
            <HeaderTemplate>
                <strong>@UIConstants.SelectPeriod</strong>
            </HeaderTemplate>
            <NoDataTemplate>
                <div class="no-data-template">
                    <TelerikFontIcon Class="k-icon k-icon-lg" Icon="@FontIcon.FilesError"></TelerikFontIcon>
                    <p>@UIConstants.NoItemsAvailable</p>
                </div>
            </NoDataTemplate>
        </TelerikDropDownList>
    </div>
    @if(ConfigurationUI.IsMidtermEnabled)
	{
        <div class="col"></div>
    }
    else
    {
        <div class="col font-700">@UIConstants.PlanType @PlanType</div>
    }
    <div class="col-auto">
        <div class="font-700">@UIConstants.SortBy</div>
    </div>
    <div class="col-5">
        <TelerikButtonGroup SelectionMode="@ButtonGroupSelectionMode.Single">
            <ButtonGroupToggleButton @bind-Selected="@NoneSelected" @onclick="() => SortProductSupplyCostsBy(x => x.Id)">None</ButtonGroupToggleButton>
            <ButtonGroupToggleButton @onclick="() => SortProductSupplyCostsBy(x => x.LocationName)">Market</ButtonGroupToggleButton>
            <ButtonGroupToggleButton @onclick="() => SortProductSupplyCostsBy(x => x.ProductName)">Product</ButtonGroupToggleButton>
        </TelerikButtonGroup>
    </div>
</div>
<div class="row m-1">
    <div class="col p-0">
        <span class="font-700; k-font-weight-bold">Product Supply and Cost</span>
        @if (IsReady)
        {
            <ProductSupplyCostDPGrid IsReady=@IsReady @ref="DPSupplyReference" ProductSupplyAndCostData="@ProductSupplyAndCostSourceData" ReadOnlyFlag="@ReadOnlyFlag" IsHistoricalPlan="@IsHistoricalPlan"></ProductSupplyCostDPGrid>
        }
    </div>
</div>
<div class="row text-end m-top">
    <div class="col">
        @{
            var productSupplyAndCostItems = (ProductSupplyAndCostData);
            if (!string.IsNullOrEmpty(RegionName) && !ReadOnlyFlag)
            {
                <AuthorizeView Policy="@(EditDpoPermissionName(RegionName))" Context="auth">
                    <TelerikButton Id="btn-save-supply-dp" ThemeColor="primary" ButtonType="@ButtonType.Submit"
                                   @onclick="(() => SaveProductSupplyCostAsync(productSupplyAndCostItems))">Save</TelerikButton>
                    <TelerikButton Id="btn-cancel-supply-dp" ButtonType="@ButtonType.Button" @onclick="(() => CancelProductSupplyCost())">Cancel</TelerikButton>
                </AuthorizeView>
            }
        }
    </div>
</div>
@if (_featureManager.IsEnabledAsync(FeatureFlags.ManualData).Result && IsReady)
{
    <div class="row m-1">
        <div class="col p-0">
            <span class="font-700; k-font-weight-bold">Manual Network Supply</span>
            <ProductSupplyCostDPGrid IsReady=@IsReady @ref='DPNetworkSupplyReference' ProductSupplyAndCostData ="@ProductSupplyAndCostNetworkData" ReadOnlyFlag="@ReadOnlyFlag" IsHistoricalPlan="@IsHistoricalPlan" IsDataInputDateVisible=true IsOverrideVisible=false IsPIMSLocationVisible=false></ProductSupplyCostDPGrid>
        </div>
    </div>
}
<TelerikWindow Modal="true"
               @bind-Visible="@StatusPopup">
    <WindowContent>
        <div class="row p-3 fs-6">@StatusMessageContent</div>
        <div class="text-center"><TelerikButton OnClick="Close">Ok</TelerikButton></div>
    </WindowContent>
</TelerikWindow>
